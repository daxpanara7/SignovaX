# Backend Environment Variables
# Copy this file to .env and fill in your values

# Application Environment: development | staging | production
APP_ENV=development

# Security — CHANGE THIS in production (min 32 chars)
SECRET_KEY=change-this-secret-key-to-something-secure-32-chars-min

# Database
DATABASE_URL=sqlite:///./smc_trading.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/smc_trading

# Binance API (required for live market data)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Optional data sources
FINNHUB_API_KEY=your_finnhub_api_key_here
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Risk Configuration
MAX_DAILY_LOSS_PCT=0.05
DEFAULT_RISK_PCT=0.01

# CORS — add your frontend origin
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Rate Limiting
RATE_LIMIT_ENABLED=true
