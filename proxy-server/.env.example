# Proxy Server Environment Variables
PORT=4000

# Apify TradingView API (optional - paid)
APIFY_API_TOKEN=your_apify_token_here

# CoinGecko (free demo key - get from https://www.coingecko.com/en/api)
COINGECKO_API_KEY=your_coingecko_demo_key_here

# Binance (no key needed for public endpoints)
BINANCE_BASE_URL=https://api.binance.com

# Cache TTL in seconds
CACHE_TTL_PRICE=10
CACHE_TTL_CANDLES=60
CACHE_TTL_INDICATORS=300

# CORS - frontend origin
ALLOWED_ORIGIN=http://localhost:3000
