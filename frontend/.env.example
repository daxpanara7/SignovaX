# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (defaults to localhost:8000 via Vite proxy)
REACT_APP_BACKEND_URL=http://localhost:8000

# Auto-login on startup (set to true for development convenience)
REACT_APP_AUTO_LOGIN=false

# Default credentials for auto-login (only used if REACT_APP_AUTO_LOGIN=true)
REACT_APP_DEFAULT_USERNAME=admin
REACT_APP_DEFAULT_PASSWORD=change_me_in_production
